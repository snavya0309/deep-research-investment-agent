# Groq API Key (required for CrewAI agents - FREE!)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Key (required for news search - free tier: 1000 searches/month)
# Get yours at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# HuggingFace token (optional, but recommended to avoid download throttling)
# Get yours at: https://huggingface.co/settings/tokens (read-only is sufficient)
HF_TOKEN=your_huggingface_token_here

# Model configuration (optional)
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Optional API auth token for FastAPI requests
API_AUTH_TOKEN=your_optional_api_token_here

# Comma-separated CORS origins for the FastAPI app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:3000,http://127.0.0.1:8501
